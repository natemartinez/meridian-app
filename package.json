{
  "name": "meridian",
  "version": "1.0.0",
  "private": true,
  "description": "Visual goal navigation powered by AI",
  "main": "main.js",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "productivity",
    "goals",
    "goal-tracking",
    "electron",
    "react",
    "vite",
    "ai-companion",
    "openrouter",
    "pomodoro",
    "skill-tracking",
    "personal-dashboard"
  ],
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k \"vite\" \"sleep 2 && ELECTRON_DEV=1 electron .\"",
    "build": "vite build",
    "electron": "ELECTRON_DEV=1 electron .",
    "start": "electron ."
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "better-sqlite3": "^12.10.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
