{
  "name": "meridian",
  "version": "1.0.0",
  "private": true,
  "description": "Visual goal navigation powered by AI",
  "main": "main.js",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "productivity",
    "goals",
    "goal-tracking",
    "electron",
    "react",
    "vite",
    "ai-companion",
    "openrouter",
    "pomodoro",
    "skill-tracking",
    "personal-dashboard"
  ],
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k \"vite\" \"sleep 2 && ELECTRON_DEV=1 electron .\"",
    "build": "vite build",
    "electron": "ELECTRON_DEV=1 electron .",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "vite": "^8.0.9",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "better-sqlite3": "^12.10.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
